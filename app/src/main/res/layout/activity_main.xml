<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <EditText
        android:id="@+id/uid"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:hint="@string/id"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="100dp"
        app:layout_constraintHorizontal_bias="0.4"
        android:background="@drawable/border" />

    <EditText
        android:id="@+id/upw"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:hint="@string/pw"
        app:layout_constraintTop_toBottomOf="@+id/uid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:background="@drawable/border"
        android:inputType="textPassword"
        app:layout_constraintHorizontal_bias="0.4"/>

    <Button
        android:id="@+id/login_btn"
        android:layout_width="100dp"
        android:layout_height="110dp"
        android:text="@string/login_btn"
        app:layout_constraintStart_toEndOf="@+id/uid"
        app:layout_constraintTop_toTopOf="@+id/uid"
        android:layout_marginStart="8dp"
        android:background="@drawable/square_button"
        />

    <TextView
        android:id="@+id/register"
        android:layout_width="80dp"
        android:layout_height="50dp"
        android:text="@string/register"
        app:layout_constraintTop_toBottomOf="@+id/upw"
        app:layout_constraintStart_toStartOf="@+id/upw"
        android:layout_marginTop="8dp"
        android:gravity="center"/>

    <TextView
        android:layout_width="145dp"
        android:layout_height="50dp"
        android:text="@string/find_pw"
        app:layout_constraintTop_toBottomOf="@+id/upw"
        app:layout_constraintStart_toEndOf="@+id/register"
        android:layout_marginTop="8dp"
        android:gravity="center"/>

</androidx.constraintlayout.widget.ConstraintLayout>